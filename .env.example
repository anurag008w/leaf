# ── Zone Study OS — Environment Configuration ──────
# Copy this file to .env and fill in your values.
# Platform-specific settings are grouped below.

# ── Core ────────────────────────────────────────────
ZONE_USERNAME=admin
ZONE_PASSWORD=change_me_pls
ZONE_DATA_DIR=./data                  # local: ./data | Docker: /data | custom: /any/path

# ── HuggingFace Backup Sync ─────────────────────────
# Required for HF Spaces deployment
HF_TOKEN=                             # HF access token (write permission)
HF_USERNAME=                          # HF username
SYNC_DATASET=myos-backup              # dataset name on HF
SYNC_INTERVAL=1800                    # sync interval in seconds (30 min)
SYNC_RESTORE=true                     # restore data from HF on startup
HUB_ENABLED=true
# HUB_URL=https://anuragw088-zone.hf.space  # override auto-detect from SPACE_ID

# ── GitHub Data Sync ────────────────────────────────
# Requires: gh CLI installed and authenticated (gh auth login)
GITHUB_SYNC_ENABLED=true
GITHUB_REPO=zone-data-backup          # private repo name (auto-created)
GITHUB_SYNC_INTERVAL=300              # auto-push interval in seconds (5 min)

# ── Platform: Render ────────────────────────────────
# Render sets $PORT automatically. Don't hardcode it.
# Free tier: spins down after 15min idle. Use cron-job.org keepalive.
# Starter tier ($7/mo): no spin-down, persistent disk.
# Render Blueprint: render.yaml (connect repo at render.com)

# ── Platform: Koyeb ─────────────────────────────────
# Koyeb auto-detects Docker. Set env vars via GitHub Actions or dashboard.
# Free tier: nano instance, may sleep after inactivity.
# GitHub Actions: .github/workflows/deploy-to-koyeb.yml
# Secret: KOYEB_API_TOKEN (app.koyeb.com → Settings → API Tokens)

# ── Platform: Back4App Containers ───────────────────
# Back4App uses Docker. Connect GitHub repo at cloud.back4app.com.
# Free tier: 256MB RAM, 10-min sleep, 1 app limit.
# GitHub Actions: .github/workflows/deploy-to-back4app.yml
# Secret: BACK4APP_ACCOUNT_KEY (cloud.back4app.com → Account → Keys)

# ── Platform: HuggingFace Spaces ────────────────────
# HF Spaces uses Docker. Set secrets in Space settings.
# Free tier: 16GB RAM, auto-sleep on inactivity.
# GitHub Actions: .github/workflows/deploy-to-hf-space.yml
# Secrets: HF_TOKEN, HF_USERNAME, HF_SPACE_NAME

# ── Platform: Fly.io ────────────────────────────────
# Fly.io uses Docker. Install flyctl CLI.
# Free tier: 3 shared VMs, 160GB bandwidth.
# Deploy: flyctl launch && flyctl deploy
# Secret: FLY_API_TOKEN (fly.io → Account → API Tokens)

# ── Platform: Oracle Cloud (Always Free) ────────────
# Full VM, no sleep, no spin-down. Most powerful free option.
# Deploy: SSH into VM, git clone, docker compose up -d
# No platform-specific secrets needed.
