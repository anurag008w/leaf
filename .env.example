# ── Required ──────────────────────────────
# At least one of these must be set for auth to work:
ZONE_USERNAME=admin
ZONE_PASSWORD=change_me_pls

# ── Security ──────────────────────────────
# 64-char hex key for encrypting user data at rest.
# If not set, one is generated and saved to data/secret.key
# WARNING: if data/ isn't persistent, key will be lost on restart.
ZONE_SECRET=

# ── Storage ──────────────────────────────
# Where user data lives on disk.
# On HF Spaces, set to /data (the only persistent volume).
ZONE_DATA_DIR=/data

# ── Sync (optional) ───────────────────────
HF_TOKEN=
# Dataset name (e.g. "username/dataset-name"). If not set, auto-creates
# "{hf_username}/zone-study-os-data" using your HF account name.
SYNC_DATASET=
# How often to auto-sync to HF (seconds, default 1800)
SYNC_INTERVAL=1800

# ── Keepalive (optional) ──────────────────
CRON_TOKEN=
CRONJOB_API_KEY=
KEEPALIVE_ENABLED=true
KEEPALIVE_CRON=*/5 * * * *
# Auto-detected from SPACE_HOST if not set (SPACE_HOST is injected by HF Spaces)
KEEPALIVE_URL=

# ── HF Spaces (auto-injected, not needed manually) ─
SPACE_ID=
SPACE_HOST=
SPACE_AUTHOR_NAME=
SPACE_REPO_NAME=
